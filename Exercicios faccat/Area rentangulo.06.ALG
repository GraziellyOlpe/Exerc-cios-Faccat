Algoritmo "Area retangulo"
// Disciplina  :Lógica de Programaçăo com visual G
// Professor   :Jajah do Grau
// Descriçăo   :Escrever um algoritimo para ler as dimensőes de um retângulo.
// Autor(a)    :Grazielly De Oliveira Pereira
// Data atual  : 25/03/2026

var
   base, altura, area: real
inicio
   escreval("=== Area do Retangulo ===")
   escreva("Base: ")
   leia(base)
   escreva("Altura: ")
   leia(altura)
   area <- base * altura
   escreval("Area: ", area:0:2)
fimalgoritmo
