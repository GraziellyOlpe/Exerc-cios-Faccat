Algoritmo "Senha"
// Disciplina  :Lógica de Programaçăo com visual G
// Professor   : Jajah Do Grau
// Autor(a)    : Grazielly De Oliveira Pereira
// Data atual  : 30/03/2025
var
senha: inteiro
inicio
   escreva("Digite a senha: ") leia(senha)
   se senha = 1234 entao
      escreval("ACESSO PERMITIDO")
   senao
      escreval("ACESSO NEGADO")
   fimse
fimalgoritmo
